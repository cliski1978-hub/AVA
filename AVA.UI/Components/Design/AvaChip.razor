<div class="@CssClass"
     @onclick="HandleClick"
     @attributes="AdditionalAttributes">
    @if (Icon is not null)
    {
        <span class="ava-chip__icon">@Icon</span>
    }
    <span>@ChildContent</span>
    @if (IsRemovable)
    {
        <button type="button"
                class="ava-chip__remove"
                @onclick="HandleRemove"
                @onclick:stopPropagation>
            &#10005;
        </button>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the visual intent for the chip.
    /// </summary>
    [Parameter]
    public string Intent { get; set; } = "neutral";

    /// <summary>
    /// Gets or sets the size variant for the chip.
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    /// <summary>
    /// Gets or sets an optional state class for the chip.
    /// </summary>
    [Parameter]
    public string State { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets whether the chip is clickable.
    /// </summary>
    [Parameter]
    public bool IsClickable { get; set; }

    /// <summary>
    /// Gets or sets whether the chip includes a remove action.
    /// </summary>
    [Parameter]
    public bool IsRemovable { get; set; }

    /// <summary>
    /// Gets or sets optional icon content.
    /// </summary>
    [Parameter]
    public RenderFragment? Icon { get; set; }

    /// <summary>
    /// Gets or sets the chip content.
    /// </summary>
    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;

    /// <summary>
    /// Gets or sets additional HTML attributes for the chip.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the click callback.
    /// </summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>
    /// Gets or sets the remove callback.
    /// </summary>
    [Parameter]
    public EventCallback OnRemove { get; set; }

    private string CssClass =>
        string.Join(" ",
            "ava-chip",
            Normalize("ava-chip", Intent, "neutral"),
            Normalize("ava-chip", Size, "md"),
            IsClickable ? "is-clickable" : string.Empty,
            string.IsNullOrWhiteSpace(State) ? string.Empty : State);

    private async Task HandleClick()
    {
        if (IsClickable)
        {
            await OnClick.InvokeAsync();
        }
    }

    private async Task HandleRemove()
    {
        await OnRemove.InvokeAsync();
    }

    private static string Normalize(string prefix, string value, string fallback)
    {
        var resolved = string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
        return resolved.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? resolved
            : $"{prefix}-{resolved}";
    }
}
