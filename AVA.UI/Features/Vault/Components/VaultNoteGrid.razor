@using AVA.UI.Features.Vault.ViewModels
@inject VaultSearchVM VM
@inject VaultNoteEditorVM EditorVM
@implements IDisposable

<div class="vault-note-grid">
    @if (VM.IsLoading)
    {
        <div class="vault-note-grid__state">Searching…</div>
    }
    else if (!VM.HasResults)
    {
        <div class="vault-note-grid__state vault-note-grid__state--empty">
            No notes found. Try adjusting your search or filters.
        </div>
    }
    else
    {
        <div class="vault-note-grid__count">@VM.ResultCount note@(VM.ResultCount == 1 ? "" : "s")</div>

        <div class="vault-note-grid__list">
            @foreach (var note in VM.Results)
            {
                var n = note;
                <div class="vault-note-grid__card" @key="n.ID"
                     @onclick="() => OpenNoteAsync(n.ID, n.VaultID)">

                    <div class="vault-note-grid__card-header">
                        <span class="vault-note-grid__title">@(n.Title ?? "Untitled")</span>
                        <span class="vault-note-grid__date">@n.UpdatedAt.ToLocalTime().ToString("MMM d")</span>
                    </div>

                    @if (n.VaultNoteVaultTags?.Any() == true)
                    {
                        <div class="vault-note-grid__tags">
                            @foreach (var jt in n.VaultNoteVaultTags)
                            {
                                <span class="vault-note-grid__tag"
                                      style="@(string.IsNullOrWhiteSpace(jt.Tag.Color) ? "" : $"border-color:{jt.Tag.Color};color:{jt.Tag.Color}")"
                                      @onclick="() => FilterByTag(jt.Tag.Name)">
                                    @jt.Tag.Name
                                </span>
                            }
                        </div>
                    }

                    <div class="vault-note-grid__preview">
                        @TruncateContent(n.Content)
                    </div>

                </div>
            }
        </div>
    }
</div>

<style>
    .vault-note-grid {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .vault-note-grid__state {
        padding: 24px;
        text-align: center;
        font-size: var(--FzSm);
        color: var(--TextMuted);
    }

    .vault-note-grid__state--empty {
        color: var(--TextFaint);
    }

    .vault-note-grid__count {
        font-size: var(--FzXs);
        color: var(--TextMuted);
        padding: 0 4px 4px;
        letter-spacing: 0.04em;
    }

    .vault-note-grid__list {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .vault-note-grid__card {
        padding: 10px 12px;
        border-radius: var(--RxMd);
        border: 1px solid var(--Border);
        background: var(--BgElevated);
        cursor: pointer;
        transition: background var(--T), border-color var(--T);
    }

    .vault-note-grid__card:hover {
        background: var(--BgHover);
        border-color: var(--BorderMid);
    }

    .vault-note-grid__card-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 4px;
    }

    .vault-note-grid__title {
        font-size: var(--FzSm);
        font-weight: 600;
        color: var(--Text);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
    }

    .vault-note-grid__date {
        font-size: var(--FzXs);
        color: var(--TextFaint);
        flex-shrink: 0;
    }

    .vault-note-grid__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 6px;
    }

    .vault-note-grid__tag {
        font-size: 10px;
        padding: 1px 6px;
        border-radius: var(--RxPill);
        border: 1px solid var(--BorderMid);
        color: var(--TextMuted);
        cursor: pointer;
        transition: all var(--T);
    }

    .vault-note-grid__tag:hover {
        border-color: var(--Accent);
        color: var(--Accent);
    }

    .vault-note-grid__preview {
        font-size: var(--FzXs);
        color: var(--TextMuted);
        line-height: 1.5;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }
</style>

@code {
    private Action? _vmHandler;

    protected override void OnInitialized()
    {
        _vmHandler = () => InvokeAsync(StateHasChanged);
        VM.OnChange += _vmHandler;
    }

    private async Task OpenNoteAsync(string noteId, string vaultId)
    {
        await EditorVM.LoadNoteAsync(vaultId, noteId);
    }

    private async Task FilterByTag(string tagName)
    {
        VM.FilterTag = tagName;
        await VM.SearchAsync();
    }

    private static string TruncateContent(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return string.Empty;
        return content.Length > 120 ? content[..120] + "…" : content;
    }

    public void Dispose()
    {
        VM.OnChange -= _vmHandler;
    }
}
