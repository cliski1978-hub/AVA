@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="quick-actions @(IsCollapsed ? "collapsed" : string.Empty)">
    <button class="quick-actions__btn @(IsSelected("Chat") ? "active" : string.Empty)" @onclick='() => SetTab("Chat")'>@(IsCollapsed ? "C" : "Chat")</button>
    <button class="quick-actions__btn @(IsSelected("Memory") ? "active" : string.Empty)" @onclick='() => SetTab("Memory")'>@(IsCollapsed ? "M" : "Memory")</button>
    <button class="quick-actions__btn @(IsSelected("Reflection") ? "active" : string.Empty)" @onclick='() => SetTab("Reflection")'>@(IsCollapsed ? "R" : "Reflection")</button>
    <button class="quick-actions__btn @(IsSelected("Settings") ? "active" : string.Empty)" @onclick='() => SetTab("Settings")'>@(IsCollapsed ? "S" : "Settings")</button>
    <button class="quick-actions__btn @(IsSelected("Canvas") ? "active" : string.Empty)" @onclick='() => SetTab("Canvas")'>@(IsCollapsed ? "Sl" : "Slate")</button>
    <button class="quick-actions__btn @(IsCanvasRouteSelected() ? "active" : string.Empty)" @onclick="OpenCanvasPage">@(IsCollapsed ? "Cv" : "Canvas")</button>
    <button class="quick-actions__btn @(IsSelected("Vault") ? "active" : string.Empty)" @onclick='() => SetTab("Vault")'>@(IsCollapsed ? "N" : "Notes")</button>
</div>

<style>
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--RxSm);
        padding: 0 var(--FzXs) var(--FzXs);
        flex-shrink: 0;
    }

    .quick-actions.collapsed {
        grid-template-columns: minmax(0, 1fr);
    }

    .quick-actions__btn {
        height: var(--SzSm);
        border-radius: var(--RxSm);
        border: 1px solid rgba(0, 214, 143, 0.3);
        background: rgba(76, 175, 80, 0.08);
        color: #81c784;
        font-family: var(--Font);
        font-size: var(--FzMd);
        cursor: pointer;
        transition: all var(--T);
        padding: 0 var(--RxMd);
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .quick-actions__btn:hover,
    .quick-actions__btn.active {
        background: rgba(76, 175, 80, 0.2);
        border-color: #4caf50;
        color: #a5d6a7;
    }
</style>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    private void SetTab(string tab)
    {
        AppState.SetSelectedNavigationItem(tab);
        if (IsCanvasRouteSelected())
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private bool IsSelected(string tab) => AppState.SelectedNavigationItem == tab;

    private void OpenCanvasPage()
    {
        NavigationManager.NavigateTo("/canvas");
    }

    private bool IsCanvasRouteSelected()
        => string.Equals(
            NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/'),
            "canvas",
            StringComparison.OrdinalIgnoreCase);
}
