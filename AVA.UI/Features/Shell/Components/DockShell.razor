@inject AppState AppState
@inject AvaSettingsService SettingsService
@inject DockShellVM VM
@inject LeftNavVM NavVM
@using AVA.UI.Features.Shell.ViewModels
@using AVA.UI.Features.Navigation.ViewModels
@using AVA.UI.Features.ChatContext.Components
@implements IDisposable

<div class="dock-shell">
    <aside class="dock-left @(NavVM.IsCollapsed ? "collapsed" : string.Empty)">
        <LeftNav OnCollapsedChanged="HandleCollapsedChanged" />
    </aside>

    <section class="dock-main">
        <ErrorSummary />
        <SessionToolbar />
        <div class="dock-content">
            @ChildContent
        </div>
    </section>

    <RightContextNav />
</div>

<style>
    .dock-shell {
        display: flex;
        height: 100vh;
        background: var(--BgBase);
        color: var(--Text);
        font-family: var(--Font);
        overflow: hidden;
    }

    .dock-left {
        width: var(--NavWidth);
        min-width: var(--NavWidth);
        border-right: 1px solid var(--Border);
        overflow: hidden;
        transition: width var(--T), min-width var(--T);
        flex-shrink: 0;
    }

    .dock-left.collapsed {
        width: var(--NavWidthCollapsed);
        min-width: var(--NavWidthCollapsed);
    }

    .dock-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 0;
    }

    .dock-content {
        flex: 1;
        overflow: auto;
        min-height: 0;
        min-width: 0;
    }
</style>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private Action? _appStateHandler;
    private Action? _navVmHandler;

    protected override async Task OnInitializedAsync()
    {
        _appStateHandler = () => InvokeAsync(StateHasChanged);
        _navVmHandler    = () => InvokeAsync(StateHasChanged);
        AppState.OnChange += _appStateHandler;
        NavVM.OnChange    += _navVmHandler;
        await VM.InitializeAsync();
    }

    private void HandleCollapsedChanged(bool isCollapsed)
    {
        // NavVM.IsCollapsed is already updated by LeftNavVM — just re-render
        StateHasChanged();
    }

    public void Dispose()
    {
        AppState.OnChange -= _appStateHandler;
        NavVM.OnChange    -= _navVmHandler;
    }
}
