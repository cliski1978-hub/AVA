@* ─────────────────────────────────────────────────────────────────────────
   AvaToggle.razor
   Purpose: On/off switch toggle with label and change callback.
   ───────────────────────────────────────────────────────────────────────── *@

<div style="display: flex; align-items: center; gap: 10px;">
    <button type="button"
            class="ava-toggle @(Checked ? "checked" : "")"
            @onclick="OnToggle"
            disabled="@Disabled"
            style="cursor: @(Disabled ? "not-allowed" : "pointer");">
        <div class="ava-toggle__switch"></div>
    </button>
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label style="font-size: 11px; color: var(--Text); cursor: pointer;" @onclick="OnToggle">
            @Label
        </label>
    }
</div>

@code {
    /// <summary>
    /// Toggle state.
    /// </summary>
    [Parameter]
    public bool Checked { get; set; }

    /// <summary>
    /// Callback when toggled.
    /// </summary>
    [Parameter]
    public EventCallback<bool> CheckedChanged { get; set; }

    /// <summary>
    /// Optional label.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Whether the toggle is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Intent (visual variant — prepared for future styling).
    /// </summary>
    [Parameter]
    public string Intent { get; set; } = "primary";

    /// <summary>
    /// Size: sm, md, lg (prepared for future styling).
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    private async Task OnToggle()
    {
        if (!Disabled)
        {
            Checked = !Checked;
            await CheckedChanged.InvokeAsync(Checked);
        }
    }
}
