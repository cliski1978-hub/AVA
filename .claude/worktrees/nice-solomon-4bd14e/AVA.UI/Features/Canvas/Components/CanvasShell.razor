    private void SyncStateFromDocument()
    {
        _documentTitle = ActiveDocument?.Title ?? string.Empty;
        _selectedBlockId = ActiveDocument?.OrderedBlocks
            .FirstOrDefault(block => string.Equals(block.Id, _selectedBlockId, StringComparison.OrdinalIgnoreCase))?.Id
            ?? ActiveDocument?.OrderedBlocks.FirstOrDefault()?.Id;
    }

    private string GetUpdatedLabel()
        => ActiveDocument?.UpdatedAt.ToLocalTime().ToString("g") ?? "Never";

    private string GetSelectedBlockText()
    {
        return SelectedBlock switch
        {
            CanvasTextBlock textBlock => textBlock.Content,
            CanvasHeadingBlock headingBlock => headingBlock.Content,
            CanvasCodeBlock codeBlock => codeBlock.Content,
            CanvasChatBlock chatBlock => chatBlock.Content,
            _ => string.Empty
        };
    }

    private string BuildAskPrompt()
    {
        var builder = new StringBuilder();
        builder.AppendLine(_askPrompt.Trim());
        builder.AppendLine();
        builder.AppendLine("Selected Canvas text:");
        builder.AppendLine(_selectionText ?? string.Empty);
        return builder.ToString().Trim();
    }

    private static string BuildMarkdown(CanvasDocument document)
    {
        var builder = new StringBuilder();
        builder.AppendLine($"# {document.Title}");
        builder.AppendLine();

        foreach (var block in document.OrderedBlocks)
        {
            switch (block)
            {
                case CanvasHeadingBlock headingBlock:
                    builder.AppendLine($"{new string('#', Math.Clamp(headingBlock.Level, 1, 6))} {headingBlock.Content}");
                    builder.AppendLine();
                    break;
                case CanvasCodeBlock codeBlock:
                    builder.AppendLine($"```{codeBlock.Language}");
                    builder.AppendLine(codeBlock.Content);
                    builder.AppendLine("```");
                    builder.AppendLine();
                    break;
                case CanvasChatBlock chatBlock:
                    builder.AppendLine($"> {chatBlock.Role}: {chatBlock.Content}");
                    builder.AppendLine();
                    break;
                case CanvasTextBlock textBlock:
                    builder.AppendLine(textBlock.Content);
                    builder.AppendLine();
                    break;
            }
        }

        return builder.ToString().Trim();
    }

    private static string BuildPlainText(CanvasDocument document)
    {
        var builder = new StringBuilder();
        builder.AppendLine(document.Title);
        builder.AppendLine(new string('=', document.Title.Length));
        builder.AppendLine();

        foreach (var block in document.OrderedBlocks)
        {
            switch (block)
            {
                case CanvasHeadingBlock headingBlock:
                    builder.AppendLine(headingBlock.Content.ToUpperInvariant());
                    builder.AppendLine();
                    break;
                case CanvasCodeBlock codeBlock:
                    builder.AppendLine(codeBlock.Content);
                    builder.AppendLine();
                    break;
                case CanvasChatBlock chatBlock:
                    builder.AppendLine($"{chatBlock.Role}: {chatBlock.Content}");
                    builder.AppendLine();
                    break;
                case CanvasTextBlock textBlock:
                    builder.AppendLine(textBlock.Content);
                    builder.AppendLine();
                    break;
            }
        }

        return builder.ToString().Trim();
    }

    private static string BuildPrintableHtml(CanvasDocument document)
    {
        var builder = new StringBuilder();
        builder.Append("<html><head><title>");
        builder.Append(document.Title);
        builder.Append("</title><style>body{font-family:Segoe UI,Arial,sans-serif;padding:40px;color:#111;}h1,h2{margin:0 0 16px;}pre{background:#f4f4f4;padding:16px;border-radius:8px;}p{line-height:1.6;}blockquote{border-left:4px solid #888;padding-left:12px;color:#333;}</style></head><body>");
        builder.Append($"<h1>{System.Net.WebUtility.HtmlEncode(document.Title)}</h1>");

        foreach (var block in document.OrderedBlocks)
        {
            switch (block)
            {
                case CanvasHeadingBlock headingBlock:
                    builder.Append($"<h2>{System.Net.WebUtility.HtmlEncode(headingBlock.Content)}</h2>");
                    break;
                case CanvasCodeBlock codeBlock:
                    builder.Append($"<pre>{System.Net.WebUtility.HtmlEncode(codeBlock.Content)}</pre>");
                    break;
                case CanvasChatBlock chatBlock:
                    builder.Append($"<blockquote><strong>{System.Net.WebUtility.HtmlEncode(chatBlock.Role)}:</strong> {System.Net.WebUtility.HtmlEncode(chatBlock.Content)}</blockquote>");
                    break;
                case CanvasTextBlock textBlock:
                    builder.Append($"<p>{System.Net.WebUtility.HtmlEncode(textBlock.Content)}</p>");
                    break;
            }
        }

        builder.Append("</body></html>");
        return builder.ToString();
    }

    private static string SanitizeFileName(string title)
    {
        var invalidCharacters = Path.GetInvalidFileNameChars();
        var sanitized = new string(title.Select(character => invalidCharacters.Contains(character) ? '_' : character).ToArray());
        return string.IsNullOrWhiteSpace(sanitized) ? "canvas-document" : sanitized;
    }

