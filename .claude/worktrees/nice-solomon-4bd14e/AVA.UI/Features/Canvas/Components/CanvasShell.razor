    private async Task CreateBlockFromSelectionAsync(CanvasBlockType blockType)
    {
        if (ActiveDocument is null)
        {
            return;
        }

        var selectedText = string.IsNullOrWhiteSpace(_selectionText)
            ? GetSelectedBlockText()
            : _selectionText!;
        if (string.IsNullOrWhiteSpace(selectedText))
        {
            return;
        }

        var selectedBlock = SelectedBlock;
        var insertOrder = selectedBlock?.SortOrder + 1 ?? ActiveDocument.Blocks.Count;
        CanvasBlock newBlock = blockType switch
        {
            CanvasBlockType.Heading => new CanvasHeadingBlock
            {
                Content = selectedText.Trim(),
                Level = 1,
                SortOrder = insertOrder
            },
            CanvasBlockType.Code => new CanvasCodeBlock
            {
                Content = selectedText,
                Language = "text",
                SortOrder = insertOrder
            },
            _ => new CanvasTextBlock
            {
                Content = selectedText.Trim(),
                SortOrder = insertOrder
            }
        };

        await CanvasDocumentService.AddBlockAsync(newBlock);
        _selectedBlockId = newBlock.Id;
        _showContextMenu = false;
        _showSelectionToolbar = false;
        _statusText = "Block created";
        SyncStateFromDocument();
    }

