    private async Task SubmitAskAvaAsync()
    {
        if (ActiveDocument is null || string.IsNullOrWhiteSpace(_selectionText))
        {
            return;
        }

        _isAsking = true;
        _statusText = "Asking AVA";
        StateHasChanged();

        try
        {
            var prompt = BuildAskPrompt();
            var modelId = State.Sessions.ActiveSession?.ModelProfile?.Id
                ?? State.Sessions.ActiveSession?.ModelEntry.Id;

            string responseContent;
            string responseRole;

            if (!string.IsNullOrWhiteSpace(modelId))
            {
                var response = await State.Sessions.SendToModelAsync(prompt, modelId);
                responseContent = response.Content ?? string.Empty;
                responseRole = State.GetModelName(modelId);
            }
            else
            {
                responseContent = prompt;
                responseRole = "AVA Request";
            }

            await CanvasDocumentService.AddBlockAsync(new CanvasChatBlock
            {
                Content = responseContent,
                Role = responseRole
            });

            _statusText = "Answer added";
            _showAskPanel = false;
            _askPrompt = string.Empty;
        }
        catch (Exception ex)
        {
            await CanvasDocumentService.AddBlockAsync(new CanvasChatBlock
            {
                Content = ex.Message,
                Role = "AVA Error"
            });
            _statusText = "Ask failed";
        }
        finally
        {
            _isAsking = false;
            SyncStateFromDocument();
            StateHasChanged();
        }
    }

