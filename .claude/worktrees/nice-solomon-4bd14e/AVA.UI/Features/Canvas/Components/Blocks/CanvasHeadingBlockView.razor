<div class="canvas-heading-block">
    <CanvasEditableBlock CssClass="canvas-editor-input canvas-editor-input--heading"
                         Value="@Block.Content"
                         ValueChanged="OnTextChanged"
                         Placeholder="Heading" />
    <span class="canvas-heading-block__level">@($"H{Block.Level}")</span>
</div>

@code {
    /// <summary>
    /// Gets or sets the heading block to render.
    /// </summary>
    [Parameter]
    public CanvasHeadingBlock Block { get; set; } = default!;

    /// <summary>
    /// Gets or sets the callback raised when the heading text changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnTextChanged { get; set; }

}
