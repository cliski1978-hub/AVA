@* ─────────────────────────────────────────────────────────────────────────
   SessionTabsPane.razor
   Namespace: AVA.UI.Components.Chat
   Purpose  : Standalone session tabs panel — dockable independently of the
              model picker. Shows all open sessions as tabs.
              Supports active session selection and broadcast group toggle.
   ───────────────────────────────────────────────────────────────────────── *@

@using AVA.UI.State
@inject AppState State
@implements IDisposable

<div class="session-tabs-pane">

    @if (!State.Sessions.Sessions.Any())
    {
        <div class="session-tabs-pane__empty">
            No open sessions — select models and click Open Sessions.
        </div>
    }
    else
    {
        <div class="session-tabs">
            @foreach (var Session in State.Sessions.Sessions)
            {
                var S           = Session;
                var IsActive    = State.Sessions.ActiveSession?.SessionId == S.SessionId;
                var InBroadcast = State.Sessions.BroadcastGroup.Contains(S);

                <div class="session-tab @(IsActive ? "session-tab--active" : "")
                                         @(InBroadcast ? "session-tab--broadcast" : "")"
                     @onclick="() => SelectSession(S.SessionId)">

                    @if (_BroadcastMode)
                    {
                        <input type="checkbox"
                               checked="@InBroadcast"
                               @onclick:stopPropagation="true"
                               @onchange="E => ToggleBroadcast(S.SessionId, (bool)(E.Value ?? false))" />
                    }

                    @if (IsActive)
                    {
                        <div class="session-tab__indicator"></div>
                    }

                    <span class="session-tab__label">@S.DisplayName</span>

                    @if (S.IsSending)
                    {
                        <span class="session-tab__sending">●</span>
                    }

                    <button class="session-tab__close"
                            @onclick:stopPropagation="true"
                            @onclick="() => State.Sessions.CloseSession(S.SessionId)">
                        ✕
                    </button>

                </div>
            }
        </div>

        <div class="session-tabs-pane__actions">
            <label class="broadcast-toggle @(_BroadcastMode ? "broadcast-toggle--active" : "")">
                <input type="checkbox"
                       checked="@_BroadcastMode"
                       @onchange="E => _BroadcastMode = (bool)(E.Value ?? false)" />
                Broadcast
            </label>

            @if (_BroadcastMode)
            {
                <button class="settings-btn settings-btn--sm"
                        @onclick="State.Sessions.SelectAllForBroadcast">
                    All
                </button>
                <button class="settings-btn settings-btn--sm"
                        @onclick="State.Sessions.ClearBroadcast">
                    None
                </button>
                @if (State.Sessions.BroadcastGroup.Any())
                {
                    <span class="session-tabs-pane__broadcast-count">
                        @State.Sessions.BroadcastGroup.Count selected
                    </span>
                }
            }
        </div>
    }

</div>

@code {
    private bool _BroadcastMode = false;

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    private void SelectSession(string SessionId)
    {
        State.Sessions.SetActiveSession(SessionId);
        StateHasChanged();
    }

    private void ToggleBroadcast(string SessionId, bool Include)
    {
        if (Include)
            State.Sessions.AddToBroadcast(SessionId);
        else
            State.Sessions.RemoveFromBroadcast(SessionId);
        StateHasChanged();
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
