@using AVA.UI.Components.Canvas
@using AVA.UI.CORE.Models.UI
@using AVA.UI.State
@inject AppState State
@inject IJSRuntime JS
@implements IDisposable

<div class="output-pane">
    <div class="output-pane__toolbar">
        <span class="output-pane__title">@State.GetMainChatTitle()</span>
        <button class="output-pane__clear" @onclick="State.ClearMainChat">Clear</button>
    </div>

    <div class="output-pane__scroll" @ref="_scrollContainer">
        @if (!Messages.Any())
        {
            <div class="output-pane__empty">No messages yet.</div>
        }
        else
        {
            <div class="output-pane__messages">
                @foreach (var message in Messages)
                {
                    <MessageBubble Message="message" />
                }
            </div>
        }

        @if (State.IsMainChatWaiting)
        {
            <div class="output-pane__typing" aria-live="polite" aria-label="Waiting for response">
                <span></span><span></span><span></span>
            </div>
        }
    </div>
</div>

<style>
.output-pane {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
}

.output-pane__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px 10px;
    border-bottom: 1px solid var(--Border);
}

.output-pane__title {
    font-size: 12px;
    font-weight: 600;
    color: var(--Text);
}

.output-pane__clear {
    border: 1px solid var(--Border);
    background: var(--BgElevated);
    color: var(--TextMuted);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 11px;
    cursor: pointer;
}

.output-pane__scroll {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 12px 10px 48px;
}

.output-pane__messages {
    display: flex;
    flex-direction: column;
}

.output-pane__empty {
    display: grid;
    place-items: center;
    min-height: 100%;
    color: var(--TextMuted);
    font-size: 12px;
}

.output-pane__typing {
    position: sticky;
    margin-left: auto;
    right: 14px;
    bottom: 14px;
    width: fit-content;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 8px 10px;
    border-radius: 999px;
    background: rgba(12, 18, 24, 0.88);
    border: 1px solid var(--Border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
    pointer-events: none;
}

.output-pane__typing span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--Success);
    opacity: 0.35;
    animation: main-chat-pulse 1.1s infinite ease-in-out;
}

.output-pane__typing span:nth-child(2) { animation-delay: 0.15s; }
.output-pane__typing span:nth-child(3) { animation-delay: 0.3s; }

@@keyframes main-chat-pulse {
    0%, 80%, 100% {
        transform: translateY(0) scale(0.9);
        opacity: 0.35;
    }

    40% {
        transform: translateY(-2px) scale(1);
        opacity: 1;
    }
}
</style>

@code {
    private ElementReference _scrollContainer;
    private int _lastCount;

    private IReadOnlyList<Message> Messages => State.GetMainChatMessages();

    protected override void OnInitialized()
    {
        State.OnChange += OnStateChanged;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Messages.Count != _lastCount)
        {
            _lastCount = Messages.Count;
            await JS.InvokeVoidAsync("avaScrollToBottom", _scrollContainer);
        }
    }

    public void Dispose()
    {
        State.OnChange -= OnStateChanged;
    }
}
