<div class="@CssClass" @attributes="AdditionalAttributes">
    <span class="ava-status-indicator__dot"></span>
    @if (ChildContent is not null)
    {
        <span class="ava-status-indicator__label">@ChildContent</span>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the visual intent for the status indicator.
    /// </summary>
    [Parameter]
    public string Intent { get; set; } = "neutral";

    /// <summary>
    /// Gets or sets the size variant for the status indicator.
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    /// <summary>
    /// Gets or sets an optional state class for the status indicator.
    /// </summary>
    [Parameter]
    public string State { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets optional label content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets additional HTML attributes for the indicator.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass =>
        string.Join(" ",
            "ava-status-indicator",
            Normalize("ava-status-indicator", Intent, "neutral"),
            Normalize("ava-status-indicator", Size, "md"),
            string.IsNullOrWhiteSpace(State) ? string.Empty : State);

    private static string Normalize(string prefix, string value, string fallback)
    {
        var resolved = string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
        return resolved.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? resolved
            : $"{prefix}-{resolved}";
    }
}
