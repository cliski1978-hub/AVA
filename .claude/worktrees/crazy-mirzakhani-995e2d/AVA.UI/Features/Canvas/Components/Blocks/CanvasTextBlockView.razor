<CanvasEditableBlock CssClass="canvas-editor-input canvas-editor-input--text"
                     Value="@Block.Content"
                     ValueChanged="OnTextChanged"
                     Placeholder="Write here..." />

@code {
    /// <summary>
    /// Gets or sets the text block to render.
    /// </summary>
    [Parameter]
    public CanvasTextBlock Block { get; set; } = default!;

    /// <summary>
    /// Gets or sets the callback raised when the text content changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnTextChanged { get; set; }

}
