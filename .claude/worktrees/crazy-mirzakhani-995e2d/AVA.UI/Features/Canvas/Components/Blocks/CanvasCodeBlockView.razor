<div class="canvas-code-block">
    <span class="canvas-code-block__language">@Block.Language</span>
    <CanvasEditableBlock CssClass="canvas-editor-input canvas-editor-input--code"
                         Value="@Block.Content"
                         ValueChanged="OnTextChanged"
                         Placeholder="Code content" />
</div>

@code {
    /// <summary>
    /// Gets or sets the code block to render.
    /// </summary>
    [Parameter]
    public CanvasCodeBlock Block { get; set; } = default!;

    /// <summary>
    /// Gets or sets the callback raised when the code text changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnTextChanged { get; set; }

}
