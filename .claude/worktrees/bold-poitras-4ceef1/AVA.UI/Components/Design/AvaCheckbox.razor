@* ─────────────────────────────────────────────────────────────────────────
   AvaCheckbox.razor
   Purpose: Styled checkbox with label and change callback.
   ───────────────────────────────────────────────────────────────────────── *@

<label class="ava-checkbox">
    <input type="checkbox"
           checked="@Checked"
           @onchange="async (e) => { Checked = (bool)e.Value; await CheckedChanged.InvokeAsync(Checked); }"
           disabled="@Disabled" />
    <div class="ava-checkbox__box">
        @if (Checked)
        {
            <span style="font-size: 10px;">✓</span>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <span style="font-size: 11px; color: var(--Text);">@Label</span>
    }
</label>

@code {
    /// <summary>
    /// Checked state.
    /// </summary>
    [Parameter]
    public bool Checked { get; set; }

    /// <summary>
    /// Callback when checked state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> CheckedChanged { get; set; }

    /// <summary>
    /// Optional label.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Whether the checkbox is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }
}
